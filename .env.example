# Copy this file to `.env.development`, `.env.staging`, or `.env.production` locally.
# Never commit real secrets.

APP_ENV=development

EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_APP_NAME=RN-EXPO
EXPO_PUBLIC_APP_SLUG=rn-expo
EXPO_PUBLIC_APP_VERSION=1.0.0
EXPO_PUBLIC_APP_BUILD_NUMBER=1

EXPO_PUBLIC_IOS_BUNDLE_IDENTIFIER=tech.reifylabs.rnexpo
EXPO_PUBLIC_ANDROID_PACKAGE=tech.reifylabs.rnexpo

EXPO_PUBLIC_API_BASE_URL=https://api.example.com
EXPO_PUBLIC_API_VERSION=v1
# When false, auth uses Expo SecureStore only. If API_BASE_URL is empty, HTTP auth is disabled automatically (dev) unless APP_ENV is production.
EXPO_PUBLIC_AUTH_USE_HTTP=true
# With HTTP auth, the API URL must be reachable from the device (LAN IP on a phone; localhost on simulators that share the host).

EXPO_PUBLIC_APP_LINKING_SCHEME=rnexpo

EXPO_PUBLIC_FEATURE_EXPERIMENTAL=false
